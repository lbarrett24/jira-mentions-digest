<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lukebarrett.jiradigest</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>-r</string>
    <string>dotenv/config</string>
    <string>/Users/luke.barrett/scripts/jira-mentions-digest/jira-digest.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/luke.barrett/scripts/jira-mentions-digest</string>

  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
