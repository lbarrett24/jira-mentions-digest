# ─── Jira ────────────────────────────────────────────────────────────────────
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Slack ────────────────────────────────────────────────────────────────────
# Bot token from your Slack app (must have chat:write and im:write scopes)
# See README.md for how to create a Slack app
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Your personal Slack user ID (not your bot's ID)
# Find it: Slack > click your name > Profile > ··· menu > Copy member ID
SLACK_USER_ID=U0XXXXXXXXX
